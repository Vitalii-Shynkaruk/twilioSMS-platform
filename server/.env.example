# Server Environment Variables
# Copy to .env and fill in values

# App
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=mysql://scl_user:scl_password@localhost:3306/scl_sms_platform
# Docker compose uses these to set MySQL passwords
MYSQL_PASSWORD=change_me_strong_mysql_password
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# Redis (for BullMQ job queues)
REDIS_URL=redis://localhost:6379
# Docker compose uses this for Redis AUTH
REDIS_PASSWORD=change_me_strong_redis_password

# JWT (MUST change in production — app will refuse to start with defaults)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Dev-only OTP bypass for local QA. Keep false in shared, staging, and production environments.
# The backend blocks this automatically when NODE_ENV=production.
DEV_MODE_LOGIN_ENABLED=false
DEV_MODE_LOGIN_SECRET=

# Admin account (seeded on first run)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_strong_admin_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email OTP through SMTP. The default uses the local server relay.
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM_EMAIL=login@sclcapital.io

# Twilio Test Credentials (optional, for twilio_test mode)
TWILIO_TEST_ACCOUNT_SID=
TWILIO_TEST_AUTH_TOKEN=

# SMS Mode: live | twilio_test | simulation
SMS_MODE=simulation

# Twilio Webhook Base URL (ngrok in dev, your domain in production)
WEBHOOK_BASE_URL=http://localhost:3001

# SMS Sending Limits
MAX_DAILY_MESSAGES_PER_NUMBER=350
MAX_MESSAGES_PER_MINUTE=60
RAMP_UP_ENABLED=true
RAMP_DAY_1_LIMIT=50
RAMP_DAY_2_LIMIT=100
RAMP_DAY_3_LIMIT=150
RAMP_DAY_4_LIMIT=200
RAMP_DAY_5_LIMIT=250
RAMP_DAY_6_LIMIT=300
RAMP_DAY_7_LIMIT=350

# Compliance
COMPLIANCE_QUIET_HOURS_START=20
COMPLIANCE_QUIET_HOURS_END=9
COMPLIANCE_TIMEZONE=America/New_York
SUPPORT_PHONE=(786) 648-7512

# Logging (debug | info | warn | error)
LOG_LEVEL=debug
