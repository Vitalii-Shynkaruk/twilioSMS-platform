// Twilio SMS Platform - Database Schema
// Designed for high-volume SMS operations (10k-20k+ messages/day)
// PostgreSQL with optimized indexes for bulk operations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & USERS
// ============================================

enum UserRole {
  ADMIN
  MANAGER
  REP
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole  @default(REP)
  isActive      Boolean   @default(true)
  avatarUrl     String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Phase 2: Rep-specific fields
  initials      String?   @unique  // "JB", "HA", etc.
  monthlyGoal   Float     @default(0)
  annualGoal    Float     @default(0)
  avatarColor   String    @default("#1c2e4a")

  // Phase 1 AI: HOT alert routing — rep mobile for SMS notifications when AI classifies HOT
  mobilePhone        String?   // E.164 format, set by admin in Settings
  hotAlertsEnabled   Boolean   @default(true)

  // Relations
  assignedLeads     Lead[]
  conversations     Conversation[]
  sentMessages      Message[]
  campaigns         Campaign[]
  numberAssignments NumberAssignment[]
  activityLogs      ActivityLog[]
  tags              Tag[]

  // Phase 2 Relations
  primaryDeals      Deal[]          @relation("PrimaryRep")
  dealEvents        DealEvent[]
  fundingEvents     FundingEvent[]
  renewalTasks      RenewalTask[]

  @@index([email])
  @@index([role, isActive])
  @@map("users")
}

// ============================================
// PHONE NUMBER MANAGEMENT
// ============================================

enum NumberStatus {
  ACTIVE
  WARMING
  COOLING
  SUSPENDED
  RETIRED
}

model PhoneNumber {
  id                  String       @id @default(cuid())
  twilioSid           String       @unique
  phoneNumber         String       @unique  // E.164 format
  friendlyName        String?
  messagingServiceSid String?
  status              NumberStatus @default(ACTIVE)
  
  // Twilio capabilities & metadata
  smsCapable          Boolean      @default(true)
  mmsCapable          Boolean      @default(false)
  voiceCapable        Boolean      @default(false)
  numberType          String?      // local, toll-free, short-code, mobile
  locality            String?      // City / State
  
  // Health & Reputation Tracking
  dailySentCount      Int          @default(0)
  dailyLimit          Int          @default(350)
  totalSent           Int          @default(0)
  totalDelivered      Int          @default(0)
  totalFailed         Int          @default(0)
  totalBlocked        Int          @default(0)
  deliveryRate        Float        @default(100.0)
  lastSentAt          DateTime?
  lastErrorAt         DateTime?
  errorStreak         Int          @default(0)
  
  // Ramp-up tracking
  rampDay             Int          @default(1)      // Day in ramp-up schedule
  rampStartDate       DateTime?
  isRamping           Boolean      @default(false)
  
  // Cooling
  coolingUntil        DateTime?
  cooldownReason      String?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Relations
  assignments         NumberAssignment[]
  messages            Message[]
  poolMemberships     NumberPoolMembership[]
  stickyConversations Conversation[] @relation("ConversationStickyNumber")
  twilioConversations Conversation[] @relation("ConversationTwilioNumber")

  @@index([status])
  @@index([dailySentCount])
  @@index([deliveryRate])
  @@index([messagingServiceSid])
  @@map("phone_numbers")
}

model NumberAssignment {
  id            String   @id @default(cuid())
  userId        String
  phoneNumberId String
  assignedDate  DateTime @default(now()) // Date-based assignment
  isActive      Boolean  @default(true)
  
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber   PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)

  @@unique([userId, phoneNumberId, assignedDate])
  @@index([userId, isActive])
  @@index([assignedDate])
  @@map("number_assignments")
}

// Number Pools for reputation grouping
model NumberPool {
  id          String   @id @default(cuid())
  name        String   // e.g., "Primary", "Warm-up", "Re-engagement"
  description String?
  dailyLimit  Int      @default(300)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     NumberPoolMembership[]
  campaigns   Campaign[]

  @@map("number_pools")
}

model NumberPoolMembership {
  id            String      @id @default(cuid())
  phoneNumberId String
  poolId        String
  addedAt       DateTime    @default(now())

  phoneNumber   PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  pool          NumberPool  @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([phoneNumberId, poolId])
  @@map("number_pool_memberships")
}

// ============================================
// LEADS
// ============================================

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  INTERESTED
  DOCS_REQUESTED
  SUBMITTED
  FUNDED
  NOT_INTERESTED
  DNC              // Do Not Contact
}

model Lead {
  id              String     @id @default(cuid())
  firstName       String
  lastName        String?
  phone           String     // E.164 format, primary identifier
  email           String?
  company         String?
  state           String?    // US state
  source          String?    // Lead source
  status          LeadStatus @default(NEW)
  
  // Soft-delete for compliance
  deletedAt       DateTime?
  
  // Assignment
  assignedRepId   String?
  assignedRep     User?      @relation(fields: [assignedRepId], references: [id], onDelete: SetNull)
  
  // Suppression & Compliance
  isSuppressed    Boolean    @default(false)
  suppressedAt    DateTime?
  suppressReason  String?
  optedOut        Boolean    @default(false)
  optedOutAt      DateTime?
  
  // Tracking
  lastContactedAt DateTime?
  lastRepliedAt   DateTime?
  contactCount    Int        @default(0)
  
  // Custom fields stored as JSON
  customFields    Json?
  notes           String?    @db.Text
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  tags            LeadTag[]
  conversations   Conversation[]
  campaignLeads   CampaignLead[]
  automationRuns  AutomationRun[]
  pipelineCards   PipelineCard[]
  deal            Deal?            // Linked deal in pipeline

  @@unique([phone])
  @@index([status])
  @@index([assignedRepId])
  @@index([isSuppressed, optedOut])
  @@index([lastContactedAt])
  @@index([createdAt])
  @@index([source])
  @@index([deletedAt])
  @@map("leads")
}

model Tag {
  id           String    @id @default(cuid())
  name         String
  color        String    @default("#6366f1") // Hex color
  createdAt    DateTime  @default(now())
  createdById  String?
  isImportList Boolean   @default(false)

  createdBy   User?     @relation(fields: [createdById], references: [id])
  leads       LeadTag[]

  @@unique([name, createdById])
  @@index([createdById])
  @@index([isImportList])
  @@map("tags")
}

model LeadTag {
  id     String @id @default(cuid())
  leadId String
  tagId  String

  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
  @@map("lead_tags")
}

// ============================================
// CONVERSATIONS & MESSAGES
// ============================================

model Conversation {
  id              String    @id @default(cuid())
  leadId          String
  assignedRepId   String?

  // Sticky sender - maintain continuity
  stickyNumberId  String?   // Preferred phone number for this conversation
  twilioNumberId  String?   // Phase 1 canonical sender number (from-number badge / send source)
  lastMessageAt   DateTime?
  lastDirection   String?   // "inbound" | "outbound"
  unreadCount     Int       @default(0)
  isActive        Boolean   @default(true)

  // Phase 1: SMS Inbox Rebuild — новые поля
  hotLead         Boolean   @default(false)   // Вручную помечается как горячий лид (Phase 1)
  leadStatus      String?   // "Interested" / "Not Interested" / "DNC"
  nextFollowupAt  DateTime? // Дата follow-up
  emailReceived   Boolean   @default(false)   // Помечен как "Email Rcv"

  // Phase 1 AI Inbox: Anthropic classifyInbound() output — written on every inbound
  aiClassification    String?   // "HOT" | "WARM" | "NURTURE" | "DEAD" | "WRONG_NUMBER"
  aiSignals           Json?     // { revenue, revenueMonthly, revenueAnnual, revenueConfidence, ask, product, industry, urgency, objections }
  aiSuggestions       Json?     // [{ type: "BEST"|"ALT", text, cta }]
  isCaliforniaNumber  Boolean   @default(false)
  aiLeadScore         Int       @default(0)   // 0-100, drives "AI Priority" sort
  aiClassifiedAt      DateTime? // Timestamp last classification ran (for HOT timer)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stickyNumber    PhoneNumber? @relation("ConversationStickyNumber", fields: [stickyNumberId], references: [id], onDelete: SetNull)
  twilioNumber    PhoneNumber? @relation("ConversationTwilioNumber", fields: [twilioNumberId], references: [id], onDelete: SetNull)
  lead            Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedRep     User?        @relation(fields: [assignedRepId], references: [id], onDelete: SetNull)
  messages        Message[]
  notes           ConversationNote[]
  deals           Deal[]       @relation("ConversationDeals")
  scheduledMessages ScheduledMessage[]

  @@unique([leadId])
  @@index([assignedRepId, lastMessageAt])
  @@index([assignedRepId])
  @@index([twilioNumberId])
  @@index([lastMessageAt])
  @@index([unreadCount])
  @@index([hotLead])
  @@index([leadStatus])
  @@index([nextFollowupAt])
  @@index([aiClassification])
  @@index([aiLeadScore])
  @@map("conversations")
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  UNDELIVERED
  BLOCKED
  RECEIVED    // For inbound
}

model Message {
  id              String           @id @default(cuid())
  conversationId  String
  twilioMessageSid String?         @unique
  
  direction       MessageDirection
  status          MessageStatus    @default(QUEUED)
  
  fromNumber      String
  toNumber        String
  body            String  @db.Text
  
  // Twilio metadata
  errorCode       String?
  errorMessage    String?  @db.Text
  
  // Tracking
  sentAt          DateTime?
  deliveredAt     DateTime?
  failedAt        DateTime?
  
  // Source tracking
  campaignId      String?
  automationRunId String?
  sentByUserId    String?
  phoneNumberId   String?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  conversation    Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser      User?            @relation(fields: [sentByUserId], references: [id], onDelete: SetNull)
  phoneNumber     PhoneNumber?     @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)
  campaign        Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([status])
  @@index([twilioMessageSid])
  @@index([campaignId])
  @@index([sentAt])
  @@index([direction, createdAt])
  @@index([phoneNumberId])
  @@index([sentByUserId])
  @@index([automationRunId])
  @@map("messages")
}

// ============================================
// CAMPAIGNS
// ============================================

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  PAUSED
  COMPLETED
  CANCELLED
}

model Campaign {
  id                String         @id @default(cuid())
  name              String
  description       String?
  status            CampaignStatus @default(DRAFT)
  isRetarget        Boolean        @default(false)
  sourceCampaignId  String?
  
  // Message template
  messageTemplate   String         @db.Text // Supports {{firstName}}, {{company}} etc.
  
  // Scheduling
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  
  // Sending config
  numberPoolId      String?
  sendingSpeed      Int            @default(60)   // Messages per minute
  dailyLimit        Int?                           // Per-campaign daily cap
  
  // Stats (denomalized for performance)
  totalLeads        Int            @default(0)
  totalSent         Int            @default(0)
  totalDelivered    Int            @default(0)
  totalFailed       Int            @default(0)
  totalBlocked      Int            @default(0)
  totalReplied      Int            @default(0)
  totalOptedOut     Int            @default(0)
  
  createdById       String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  createdBy         User           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  numberPool        NumberPool?    @relation(fields: [numberPoolId], references: [id], onDelete: SetNull)
  sourceCampaign    Campaign?      @relation("CampaignRetargetLineage", fields: [sourceCampaignId], references: [id], onDelete: SetNull)
  retargetCampaigns Campaign[]     @relation("CampaignRetargetLineage")
  leads             CampaignLead[]
  messages          Message[]

  @@index([status])
  @@index([createdById])
  @@index([scheduledAt])
  @@index([isRetarget])
  @@index([sourceCampaignId])
  @@map("campaigns")
}

enum CampaignLeadStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  REPLIED
  OPTED_OUT
  SKIPPED
}

model CampaignLead {
  id           String             @id @default(cuid())
  campaignId   String
  leadId       String
  status       CampaignLeadStatus @default(PENDING)
  
  sentAt       DateTime?
  deliveredAt  DateTime?
  repliedAt    DateTime?
  
  // Track which number sent to this lead
  fromNumber   String?
  errorCode    String?
  
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  campaign     Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead         Lead               @relation(fields: [leadId], references: [id])

  @@unique([campaignId, leadId])
  @@index([campaignId, status])
  @@index([leadId])
  @@map("campaign_leads")
}

// ============================================
// PIPELINE
// ============================================

model PipelineStage {
  id            String         @id @default(cuid())
  name          String
  order         Int
  color         String         @default("#6366f1")
  isDefault     Boolean        @default(false)
  mappedStatus  LeadStatus?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  cards         PipelineCard[]

  @@index([order])
  @@map("pipeline_stages")
}

model PipelineCard {
  id          String        @id @default(cuid())
  leadId      String
  stageId     String
  position    Int           @default(0)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stage       PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([leadId])
  @@index([stageId, position])
  @@map("pipeline_cards")
}

// ============================================
// AUTOMATION
// ============================================

enum AutomationType {
  LEAD_CREATED
  STATUS_CHANGED
  KEYWORD_RECEIVED
  NO_REPLY
  MANUAL
  TAG_RULE
  FOLLOW_UP_SEQUENCE
}

model AutomationRule {
  id            String         @id @default(cuid())
  name          String
  type          AutomationType
  isActive      Boolean        @default(true)
  
  // Trigger config (JSON)
  triggerConfig Json           
  // e.g., { "type": "no_reply", "delayDays": 3, "maxAttempts": 3 }
  // e.g., { "type": "keyword", "keywords": ["info", "interested"] }
  
  // Action config (JSON)
  actionConfig  Json           
  // e.g., { "type": "send_template", "templateId": "...", "moveToStage": "..." }
  // e.g., { "type": "tag_lead", "tagId": "...", "assignRep": "..." }
  
  // Schedule constraints
  sendAfterHour   Int          @default(9)   // Don't send before 9am
  sendBeforeHour  Int          @default(20)  // Don't send after 8pm
  sendOnWeekends  Boolean      @default(false)
  
  priority        Int          @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  runs            AutomationRun[]
  templates       AutomationTemplate[]

  @@index([type, isActive])
  @@map("automation_rules")
}

model AutomationTemplate {
  id               String         @id @default(cuid())
  automationRuleId String
  sequenceOrder    Int            @default(1)  // Order in follow-up sequence
  delayDays        Int            @default(1)  // Days to wait before sending
  messageTemplate  String  @db.Text             // Supports variable substitution
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  automationRule   AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)

  @@index([automationRuleId, sequenceOrder])
  @@map("automation_templates")
}

model AutomationRun {
  id               String         @id @default(cuid())
  automationRuleId String
  leadId           String
  
  currentStep      Int            @default(0)
  isActive         Boolean        @default(true)
  isPaused         Boolean        @default(false)
  pauseReason      String?        // "reply_detected", "opted_out", "manual"
  
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  completedAt      DateTime?
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  automationRule   AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  lead             Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([isActive, nextRunAt])
  @@index([leadId])
  @@index([automationRuleId])
  @@index([automationRuleId, isActive])
  @@map("automation_runs")
}

// ============================================
// SUPPRESSION LIST
// ============================================

model SuppressionEntry {
  id          String   @id @default(cuid())
  phone       String   @unique  // E.164
  reason      String   // "STOP", "manual", "bounce", "complaint"
  source      String?  // Where the suppression came from
  createdAt   DateTime @default(now())

  @@map("suppression_list")
}

// ============================================
// ACTIVITY LOG
// ============================================

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // "lead.created", "message.sent", "campaign.started" etc.
  entityType  String?  // "lead", "campaign", "message"
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("activity_logs")
}

// ============================================
// SYSTEM SETTINGS
// ============================================

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ============================================
// MESSAGE QUEUE (for high-volume processing)
// ============================================

enum QueueItemStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model MessageQueue {
  id            String          @id @default(cuid())
  campaignId    String?
  leadId        String
  phoneNumberId String?
  
  toNumber      String
  messageBody   String  @db.Text
  
  status        QueueItemStatus @default(PENDING)
  priority      Int             @default(0)
  attempts      Int             @default(0)
  maxAttempts   Int             @default(3)
  
  scheduledFor  DateTime        @default(now())
  processedAt   DateTime?
  failedAt      DateTime?
  errorMessage  String?
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status, scheduledFor, priority])
  @@index([campaignId, status])
  @@index([leadId])
  @@map("message_queue")
}

// ============================================
// DAILY NUMBER STATS (for monitoring)
// ============================================

model DailyNumberStats {
  id            String   @id @default(cuid())
  phoneNumberId String
  date          DateTime @db.Date

  
  sent          Int      @default(0)
  delivered     Int      @default(0)
  failed        Int      @default(0)
  blocked       Int      @default(0)
  replies       Int      @default(0)
  optOuts       Int      @default(0)
  deliveryRate  Float    @default(100.0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([phoneNumberId, date])
  @@index([date])
  @@map("daily_number_stats")
}

// ============================================
// PHASE 2: DEAL PIPELINE & COMMAND CENTER
// ============================================

enum DealStage {
  NEW_LEAD
  ENGAGED_INTERESTED
  QUALIFIED
  SUBMITTED_IN_REVIEW
  APPROVED_OFFERS
  COMMITTED_FUNDING
  FUNDED
  NURTURE
  CLOSED
}

enum ProductType {
  MCA
  LOC
  EQUIPMENT
  HELOC
  SBA
  CRE
  BRIDGE
}

enum CommitSubStatus {
  DOCS_REQUESTED
  DOCS_SIGNED
  FUNDING
}

model Client {
  id              String    @id @default(cuid())
  businessName    String
  contactName     String?
  phone           String?   @unique
  email           String?
  monthlyRevenue  String?
  state           String?
  totalFunded     Float     @default(0)
  fundingCount    Int       @default(0)
  lastFundedDate  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  deals           Deal[]

  @@index([phone])
  @@index([businessName])
  @@map("clients")
}

model Deal {
  id                String          @id @default(cuid())
  clientId          String
  assignedRepId     String
  leadId            String?         @unique  // Link back to source lead
  assistingRepIds   Json?           // JSON array of user IDs

  // Stage
  stage             DealStage       @default(NEW_LEAD)
  stageLabel        String          @default("New Lead") // Exact display name
  productType       ProductType?
  dealAmount        Float?
  submittedAmount   Float?
  needsAmount       Boolean         @default(true)

  // Deal tracking
  nextAction        String?
  nextActionDue     DateTime?
  lastActivityAt    DateTime        @default(now())
  lastReplyAt       DateTime?
  daysInStage       Int             @default(0)
  staleDays         Int             @default(0)

  // App & Offer tracking
  appSubmitted      Boolean         @default(false)
  lenderEngaged     Boolean         @default(false)

  // Committed sub-status
  commitSubStatus   CommitSubStatus?
  daysInSubStatus   Int             @default(0)

  // Funding
  fundedDate        DateTime?
  cycleTime         Int?            // days from app_submitted to funded

  // Nurture / Close
  prevOffer         Float?          // prior offer amount for Nurture pipeline value
  lostReason        String?
  disqualReason     String?

  // Follow-up
  followUpDate      DateTime?
  followUpType      String?         // renewal | nurture | statement | timing | reengage
  followUpNote      String?         @db.Text
  externalFundedDate DateTime?

  // Import tracking
  importBatch       String?         // batch ID for CSV imports
  originatorName    String?         // preserved text for imported deals
  lender            String?
  notes             String?         @db.Text
  clientNotes       String?         @db.Text
  isHot             Boolean         @default(false)

  // Phase 1: SMS Inbox — deal создан из SMS
  createdFromSms      Boolean       @default(false)
  smsConversationId   String?       // FK к conversation
  createdByUserId     String?       // кто создал deal

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  client            Client          @relation(fields: [clientId], references: [id])
  assignedRep       User            @relation("PrimaryRep", fields: [assignedRepId], references: [id])
  lead              Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  smsConversation   Conversation?   @relation("ConversationDeals", fields: [smsConversationId], references: [id], onDelete: SetNull)
  offers            Offer[]
  fundingEvents     FundingEvent[]
  dealEvents        DealEvent[]
  renewalTasks      RenewalTask[]

  @@index([stage])
  @@index([assignedRepId])
  @@index([clientId])
  @@index([lastActivityAt])
  @@index([fundedDate])
  @@index([nextActionDue])
  @@index([followUpDate])
  @@index([stage, assignedRepId])
  @@index([importBatch])
  @@index([leadId])
  @@index([smsConversationId])
  @@index([createdFromSms])
  @@map("deals")
}

model Offer {
  id            String      @id @default(cuid())
  dealId        String
  lenderName    String
  amount        Float
  termMonths    Int?
  rateFactor    Float?
  terms         String?     @db.Text
  expiryDays    Int?        // urgency display
  productType   ProductType?
  isAccepted    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  deal          Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("offers")
}

model FundingEvent {
  id            String      @id @default(cuid())
  dealId        String
  repId         String?
  amountFunded  Float
  lender        String?
  termMonths    Int?
  rate          Float?
  productType   ProductType?
  fundedDate    DateTime?
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())

  deal          Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  rep           User?       @relation(fields: [repId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([repId])
  @@index([fundedDate])
  @@index([repId, fundedDate])
  @@map("funding_events")
}

model DealEvent {
  id          String   @id @default(cuid())
  dealId      String
  repId       String?
  eventType   String   // stage_change, action_completed, call_logged, sms_sent, offer_added, note, etc.
  fromStage   String?
  toStage     String?
  note        String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  rep         User?    @relation(fields: [repId], references: [id], onDelete: SetNull)

  @@index([dealId, createdAt])
  @@index([repId, createdAt])
  @@index([eventType])
  @@index([createdAt])
  @@map("deal_events")
}

enum RenewalTaskStatus {
  PENDING
  COMPLETED
  OVERDUE
  SKIPPED
}

model RenewalTask {
  id          String             @id @default(cuid())
  dealId      String
  repId       String?
  taskType    String             // 35d_checkin, midpoint, payoff_30d
  dueDate     DateTime
  status      RenewalTaskStatus  @default(PENDING)
  completedAt DateTime?
  notes       String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  deal        Deal               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  rep         User?              @relation(fields: [repId], references: [id], onDelete: SetNull)

  @@index([dueDate, status])
  @@index([repId])
  @@index([dealId])
  @@map("renewal_tasks")
}

model Goal {
  id          String   @id @default(cuid())
  entityType  String   // "team" | "user"
  entityId    String   // "team" or user ID
  monthlyGoal Float    @default(0)
  annualGoal  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([entityType, entityId])
  @@map("goals")
}

// ============================================
// PHASE 1: SMS INBOX REBUILD — НОВЫЕ ТАБЛИЦЫ
// ============================================

enum TemplateVisibility {
  PRIVATE
  TEAM
  GLOBAL
}

model SmsTemplate {
  id          String             @id @default(cuid())
  name        String
  body        String             @db.Text
  category    String?            // "follow_up", "first_touch", etc.
  visibility  TemplateVisibility @default(PRIVATE)
  createdById String
  usageCount  Int                @default(0)
  lastUsedAt  DateTime?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  favorites   SmsTemplateFavorite[]
  usageLogs   SmsTemplateUsageLog[]

  @@index([createdById])
  @@index([visibility])
  @@index([category])
  @@map("sms_templates")
}

model SmsTemplateFavorite {
  id         String @id @default(cuid())
  userId     String
  templateId String

  template   SmsTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@map("sms_template_favorites")
}

model SmsTemplateUsageLog {
  id             String   @id @default(cuid())
  userId         String
  templateId     String
  conversationId String?
  usedAt         DateTime @default(now())

  template       SmsTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([templateId])
  @@index([usedAt])
  @@map("sms_template_usage_log")
}

enum ScheduledMessageStatus {
  PENDING
  SENT
  CANCELLED
}

model ScheduledMessage {
  id             String                 @id @default(cuid())
  conversationId String
  body           String                 @db.Text
  scheduledAt    DateTime
  status         ScheduledMessageStatus @default(PENDING)
  createdById    String
  fromNumber     String                 // E.164

  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  conversation   Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([conversationId])
  @@map("scheduled_messages")
}

model ConversationNote {
  id             String   @id @default(cuid())
  conversationId String
  dealId         String?  // Опциональная связь с deal
  body           String   @db.Text
  createdById    String
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([dealId])
  @@map("conversation_notes")
}
